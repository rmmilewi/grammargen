// Grammar for parsing Magic: The Gathering card rules text
// Using Earley parser for context-sensitive parsing

start: card_text

// Card text consists of one or more abilities separated by newlines
card_text: ability_with_period (NEWLINE ability_with_period)*

// Allow periods at the end of abilities, optionally followed by reminder text
?ability_with_period: ability "."?
                    | ability "." reminder_text
                    | ability "." ability_restriction "."?
                    | ability "." ability "."?
                    | ability "." ability "." reminder_text

// ==================== ABILITY TYPES ====================
// Different types of abilities - grouped by category
ability: // Core ability types
       | keyword_ability      // Single-word abilities like Flying, Vigilance
       | activated_ability    // Abilities with costs followed by effects
       | triggered_ability    // When/Whenever/At triggered abilities
       | static_ability       // Continuous effects
       | modal_ability        // Choose one/more abilities
       | if_would_ability     // Replacement effects

       // Zone transition abilities
       | enters_ability       // Abilities about entering the battlefield
       | as_enters_ability    // "As this enters..." abilities

       // Descriptive abilities
       | identity_ability     // Abilities that define what something is
       | possessive_ability   // Abilities that define characteristics

       // Special ability types
       | planeswalker_ability // Loyalty abilities
       | spell_cost_modification // Abilities that modify spell costs

       // Mechanic-specific abilities
       | ward_ability         // Ward mechanic
       | equip_ability        // Equip mechanic
       | land_ability         // Land mana abilities
       | crew_ability         // Crew mechanic
       | enchant_ability      // "Enchant X" keyword
       | enchanted_ability    // "Enchanted X gets/has/gains..." effects
       | changeling_ability   // Changeling mechanic
       | hexproof_from_ability // Hexproof from mechanic

       // Named keyword mechanics
       | landfall_ability     // Landfall mechanic
       | threshold_ability    // Threshold mechanic
       | flashback_ability    // Flashback mechanic
       | surveil_ability      // Surveil mechanic
       | mill_ability         // Mill mechanic
       | raid_ability         // Raid mechanic
       | morbid_ability       // Morbid mechanic
       | choose_one_ability   // Choose one mechanic

       // Player state abilities
       | player_state_ability // "You have hexproof", "You can't lose the game"

       // Special game rules
       | opening_hand_ability  // "If this card is in your opening hand..."
       | deck_rule_ability     // "A deck can have any number of cards named ~"

       // Simple abilities and text
       | effect               // General effects
       | simple_effect        // Simple effect patterns
       | keyword_list         // List of keywords
       | reminder_text_only   // Just reminder text
       | empty_line           // Empty line

// ==================== KEYWORD ABILITIES ====================
// Single word or phrase abilities
keyword_ability: keyword reminder_text?

// Keywords - grouped by category
keyword: // Evergreen combat keywords
       | "First strike"i
       | "Double strike"i
       | "Vigilance"i
       | "Menace"i
       | "Trample"i
       | "Reach"i
       | "Lifelink"i
       | "Deathtouch"i

       // Evergreen non-combat keywords
       | "Hexproof"i
       | "Indestructible"i
       | "Flash"i
       | "Flying"i
       | "Haste"i
       | "Defender"i

       // Keywords with parameters
       | "Protection"i protection_detail?
       | "Ward"i ward_cost?
       | "Kicker"i kicker_cost
       | "Scry"i NUMBER

       // Set-specific keywords
       | "Prowess"i
       | "Threshold"i
       | "Raid"i
       | "Morbid"i
       | "Landfall"i

// List of keywords separated by commas
keyword_list: keyword_list_item ("," keyword_list_item)+ reminder_text?

// Individual item in a keyword list (keyword or hexproof from)
keyword_list_item: keyword
                 | "hexproof from"i hexproof_from_target

// Protection details
protection_detail: "from" protection_target

// Protection targets
protection_target: color
                 | "everything"i
                 | permanent_type
                 | "converted mana cost"i NUMBER
                 | "mana value"i NUMBER  // Updated terminology

// Kicker cost - consolidated
kicker_cost: "{" (mana_cost | NUMBER | color_symbol) "}" ("{" (NUMBER | color_symbol) "}")? kicker_reminder?

// Kicker reminder - consolidated
kicker_reminder: "(" "You may pay an additional"i (mana_cost | "{" NUMBER "}" | "{" color_symbol "}") "as you cast this spell."i ")"

// ==================== ACTIVATED ABILITIES ====================
// Abilities with cost: effect format
activated_ability: activation_cost ":" effect activation_restriction?
                 | activation_cost ":" effect "." activation_restriction
                 | activation_cost ":" compound_effect activation_restriction?
                 | activation_cost ":" compound_effect "." activation_restriction
                 | activation_cost ":" "you may"i effect
                 | activation_cost ":" "you may"i effect "." activation_restriction
                 // Conditional activated abilities: "{COST}: If ~ is TYPE, it becomes..."
                 | activation_cost ":" conditional_activated_effect

// Activation costs - consolidated
// Built from cost (simple costs) + combination patterns
activation_cost: cost
               // Mana + tap combinations
               | mana_cost "," "{T}"
               | mana_only_cost "," "{T}" "," secondary_cost_action
               | mana_cost "," "{T}" "," secondary_cost_action
               // Tap + secondary action
               | "{T}" "," secondary_cost_action
               // Mana + secondary action (no tap)
               | mana_only_cost "," secondary_cost_action
               | mana_cost "," secondary_cost_action
               // Counter removal as standalone cost
               | "Remove"i counter_amount counter_type ("counter"i | "counters"i) "from"i entity
               | "Remove"i counter "from"i entity
               // Tap untapped creatures
               | "{T}" "," "Tap"i NUMBER "untapped"i (creature_type | creature_type_plural) "you control"i
               // Exile from zone costs
               | mana_cost "," "Exile"i entity "from"i zone
               | "Exile"i entity "from"i zone

// Secondary cost actions (used after mana and/or tap)
secondary_cost_action: "Sacrifice"i sacrifice_target
                     | "Sacrifice"i "another"i permanent_type
                     | "Exile"i exile_target
                     | "Put"i counter "on"i entity
                     | "Remove"i counter "from"i entity

// Simple mana cost (single symbol in braces)
mana_only_cost: "{" (mana_cost | NUMBER | color_symbol) "}"

// Activation restrictions
activation_restriction: "Activate only as a sorcery"i
                      | "Activate only once"i
                      | "Activate only once each turn"i
                      | "Activate only during your turn"i
                      | "Activate only if"i condition_clause

// Conditional activated effects: "If ~ is a TYPE, it becomes..."
conditional_activated_effect: "If"i entity "is a"i creature_type "," entity become_verb /[^.]+/
                            | "If"i entity "is a"i creature_type "," entity become_verb /[^"]+/ QUOTED_TEXT?

// Become verbs for conditional effects
become_verb: "becomes a"i
           | "becomes"i

// ==================== OPENING HAND ABILITIES ====================
// Abilities that check if the card is in your opening hand
opening_hand_ability: "If this card is in your opening hand"i "," "you may begin the game with it on the battlefield"i
                    | "If this card is in your opening hand"i "," "you may reveal it"i /[^.]+/

// ==================== DECK RULES ====================
// Special deck construction rules
deck_rule_ability: "A deck can have any number of cards named ~"i

// ==================== ABILITY RESTRICTIONS ====================
// Trailing restrictions on abilities (e.g., "This ability triggers only once each turn")
ability_restriction: "This ability triggers only once each turn"i
                   | "This ability triggers only once"i
                   | "This ability costs"i mana_cost "less to activate for each"i entity
                   | entity "can only be dealt damage by"i entity

// ==================== TRIGGERED ABILITIES ====================
// When/Whenever/At... trigger, effect
triggered_ability: trigger_condition "," trigger_effect

// Trigger effect types
trigger_effect: optional_may? effect reminder_suffix?
              | optional_may? specific_effect
              | optional_may? compound_effect reminder_suffix?
              | if_clause effect
              | if_clause compound_effect
              | if_clause "," optional_may? effect
              | "if it was kicked"i "," sacrifice_ability
              | "that player loses"i NUMBER "life"i
              // "draw 1 card if it was attacking. Otherwise, ..."
              | effect "if"i condition_clause "." "Otherwise"i "," effect
              // "that player gets N poison counters"
              | entity "gets"i counter reminder_text?

// Specific effect types for triggered abilities
specific_effect: search_effect
               | draw_effect
               | gain_life_effect
               | conditional_effect
               | create_effect
               | compound_effect

// Trigger conditions
trigger_condition: "When"i when_clause
                 | "Whenever"i whenever_clause
                 | "At"i at_clause
                 | "Raid"i "—"i raid_clause

// Shared trigger events used by both when_clause and whenever_clause
trigger_event: entity "enters"i
             | entity "enters the battlefield"i
             | entity "attacks"i
             | entity "dies"i
             | "you cast"i spell_type
             | "~ or another nontoken"i creature_type "you control enters"i

// When clauses - grouped by category
when_clause: trigger_event

           // Dies/graveyard (when-specific)
           | entity "dies"i "," if_clause
           | entity "is put into a graveyard from the battlefield"i
           | entity "enters or dies"i

           // Spell-related (when-specific)
           | "it was kicked"i
           | "this spell was kicked"i

           // Counter-related
           | entity "enters with"i counter_amount? counter "on it"i
           | entity "enters the battlefield with"i counter_amount? counter "on it"i

           // Sacrifice trigger
           | "you sacrifice this Aura"i

           // When conditions with supplementary clauses
           | entity "enters"i "," entity "may"i /[^.]+/

           // "you next cast a spell this turn"
           | "you next cast"i spell_type "this turn"i

           // Miscellaneous
           | "you do"i
           // "when there are N or more counters on"
           | "there are"i NUMBER "or more"i counter_type "counters on"i entity

// Whenever clauses - grouped by category
whenever_clause: trigger_event
               // Combat-related (whenever-specific)
               | entity "blocks"i
               | entity "becomes blocked"i
               | entity "deals combat damage to"i entity
               | "a creature deals combat damage to a player"i
               | "a creature you control with"i ability_granted "deals combat damage to"i entity
               | entity "attacks while you control a creature with power"i NUMBER "or greater"i
               | "you attack with"i NUMBER "or more creatures"i
               | color creature_type "you control attacks"i
               | "a" color creature_type "you control attacks"i
               | "a"i color "creature you control attacks"i
               // Combat damage with turn restriction
               | entity "deals combat damage to"i entity "during your turn"i
               | "a creature you control deals combat damage"i "during your turn"i
               | entity "deals combat damage to a player"i
               // Nontoken non-TYPE patterns
               | "a nontoken"i "," "non-"i creature_type entity "dies"i
               | "a nontoken, non-"i creature_type entity "dies"i

               // Life gain
               | "you gain life"i
               | "you gain life for the first time"i life_gain_timing?

               // Card draw
               | "you draw"i draw_clause
               | "you draw your second card each turn"i

               // Combined enter/attack triggers
               | entity "enters or attacks"i

               // "a TYPE you control enters"
               | "a"i creature_type "you control enters"i

               // Enters battlefield (whenever-specific)
               | "a creature you control enters"i
               | entity "you control enters"i
               | "another nontoken"i creature_type "you control enters"i
               | "a creature with power"i NUMBER "or greater enters the battlefield under your control"i
               | "a creature you control with power"i NUMBER "or greater enters"i

               // Dies (whenever-specific)
               | entity "you control dies"i
               | "this creature or another"i entity "dies"i
               | entity "or"i entity "dies"i
               | entity "or another"i entity "dies"i
               | "a creature an opponent controls dies"i
               | "another nontoken creature dies"i

               // Spell casting (whenever-specific)
               | "you cast"i spell_type "during"i cast_timing
               | "an opponent casts"i spell_type
               | "an opponent casts"i spell_type "," "that player"i /[^.]+/
               | "a player casts a spell"i
               | "an opponent casts a"i color "or"i color "spell"i
               | "an opponent casts a"i color "or"i color card_type "or"i card_type "spell"i

               // Counter-related
               | "you put one or more"i counter "on"i entity
               | "you put one or more +1/+1 counters on"i entity
               | "one or more"i counter "are put on"i entity
               | "one or more"i counter_type "counters are put on"i entity

               // Opponent events
               | "an opponent loses life"i
               | "an opponent discards a card"i
               | "an opponent draws a card"i
               | "a source you control deals noncombat damage to an opponent"i

               // General event patterns
               | "you attack"i
               | "one or more"i entity "attack"i
               | entity "becomes untapped"i
               | entity "becomes tapped"i
               // Damage-triggered death
               | "a creature dealt damage by"i entity "this turn dies"i

               // First time per turn attacks
               | entity "attacks for the first time each turn"i

               // Damage dealt to player with optional may
               | entity "deals combat damage to"i entity "," "you may"i /[^.]+/

               // Spell cast with target condition
               | "you cast a spell that targets"i entity

               // Whenever you cast a spell pattern (unqualified)
               | "you cast"i "a spell"i
               | "you cast"i spell_type "," /[^.]+/

               // Creature with power condition enters
               | "another creature you control with power"i NUMBER "or less enters"i

               // Spell of chosen color
               | "you cast a spell of the chosen color"i

// Life gain timing
life_gain_timing: "during each of your turns"i | "each turn"i

// Cast timing
cast_timing: "an opponent's turn"i | "your turn"i

// Draw clause
draw_clause: "your second card each turn"i | "a card"i | "cards"i | NUMBER "card"i | NUMBER "cards"i

// At clauses - beginning of phase/step
at_clause: "the beginning of"i phase_owner phase_type
         | "the beginning of combat on your turn"i
         | "the beginning of your end step"i
         | "the beginning of the end step"i
         | "the beginning of the next end step"i
         | "the beginning of each end step"i
         | "the beginning of each combat"i

// Phase owner
phase_owner: "your"i | "each"i | "each player's"i | "each opponent's"i

// Game phases
phase_type: "upkeep"i
          | "draw step"i
          | "main phase"i
          | "combat"i
          | "end step"i
          | "turn"i

// Raid clause
raid_clause: "When"i when_clause "," "if you attacked this turn"i
           | "Whenever"i whenever_clause "," "if you attacked this turn"i

// Optional may clause
optional_may: "you may"i

// If clause
if_clause: "if"i condition_clause ","
         | "if"i "it was kicked"i ","
         | "if"i "this spell was kicked"i ","

// ==================== PLAYER STATE ABILITIES ====================
// Abilities that grant the player states or restrict game actions
player_state_ability: "You have"i ability_granted reminder_text?
                    | "You have"i "no maximum hand size"i
                    | "You can't lose the game"i "and your opponents can't win the game"i
                    | "You may cast spells as though they had flash"i
                    | "You may cast spells from your hand without paying their mana costs"i
                    | "You may play an additional land on each of your turns"i
                    // Complex player abilities
                    | "You may pay"i mana_cost "rather than pay this spell's mana cost"i "if"i condition_clause
                    | "During your turn"i "," "you may play"i /[^.]+/
                    | "During each of your turns"i "," "you may play"i /[^.]+/
                    | "You may cast this card from your graveyard"i "by"i /[^.]+/
                    | "You may cast this card as though it had flash if you pay"i mana_cost "more to cast it"i
                    | "You may cast"i target entity "from"i zone duration?
                    | "If an effect would"i /[^,]+/ "," "it"i /[^.]+/ "instead"i
                    // "If a spell or ability an opponent controls causes you to discard this card, put it onto the battlefield instead..."
                    | "If"i /[^,]+/ "causes you to discard this card"i "," /[^.]+/
                    // Look/cast from top of library
                    | "You may look at the top card of your library any time"i
                    | "You may cast"i card_type "spells from the top of your library"i
                    | "You can spend mana of any type to cast"i card_type "spells"i

// ==================== STATIC ABILITIES ====================
// Static abilities - consolidated by pattern
static_ability: // Granting abilities: entity_grant verb ability [duration] [reminder]
              | entity_grant ("have"i | "has"i | "gains"i | "gain"i) ability_granted duration? reminder_suffix?

              // Stat modifications: entity_grant verb stat [suffix|for_each]
              | entity_grant ("get"i | "gets"i) stat_modifier (stat_modifier_suffix | for_each_clause)?

              // Compound stat + ability: "gets +X/+Y and gains Z"
              | entity_grant ("gets"i | "get"i) stat_modifier "and"i ("gains"i | "gain"i | "has"i | "have"i) ability_granted duration? reminder_suffix?
              // Additional conditional: "~ gets +5/+5 as long as"
              | entity "gets an additional"i stat_modifier "as long as"i condition_clause

              // Prevention effects
              | "Prevent all"i damage_type? "damage that would be dealt to"i entity
              | "Prevent all"i damage_type? "damage that would be dealt to and dealt by"i entity

              // Restriction effects
              | entity "can't"i action
              | entity "doesn't untap during"i untap_timing
              | entity "attacks each combat if able"i

              // Enter tapped effects
              | entity ("enter"i | "enters"i) "tapped"i

              // Type addition effects
              | entity "has"i ability_granted "and gains"i type_addition
              | entity "gains"i type_addition

              // Entity has/gains ability as long as condition
              | entity ("has"i | "gains"i) ability_granted "as long as"i condition_clause

              // Conditional static abilities (recursive — covers all static patterns)
              | "As long as"i condition_clause "," static_ability

              // "During your turn" conditional static abilities (recursive)
              | "During your turn"i "," static_ability reminder_text?

              // Activated abilities restriction
              | "Activated abilities of sources with the chosen name can't be activated unless they're mana abilities"i

              // Spells cost reduction (static form)
              | spell_type_desc "you cast cost"i "{" NUMBER "}" cost_direction

// Entity that is granted an ability or stat modification
entity_grant: "You"
            | entity
            | "Each"i permanent_type "you control"i entity_grant_with?
            | "Each"i creature_type "you control"i entity_grant_with?
            // "Other X you control [with Y]"
            | "Other"i entity_grant_type "you control"i entity_grant_with?
            | "Other creatures you control"i entity_grant_with?
            // "Creatures you control [with Y]"
            | "Creatures you control"i entity_grant_with?
            | "Attacking creatures you control"i
            | "Attacking"i creature_type_plural "you control"i
            // Singular: "Attacking Vampires you control" (using creature_type)
            | "Attacking"i creature_type "you control"i
            // "TYPE_PLURAL you control"
            | creature_type_plural "you control"i
            // "Each other X you control"
            | "Each other"i entity_grant_type "you control"i
            // Compound entity grant: "Xs you control and other Ys you control"
            | creature_type_plural "you control and other"i creature_type_plural "you control"i
            // Color creatures you control
            | "Other"i color "creatures you control"i

            // Chosen type/color qualifiers
            | entity "of the chosen type"i "you control"i?
            | entity "of the chosen color"i

// Entity grant subject type (creature_type with optional plural/creatures suffix)
entity_grant_type: creature_type
                 | creature_type_plural
                 | creature_type "creatures"i

// Optional "with" qualifier for entity_grant
entity_grant_with: "with"i ability_granted
                 | "with"i counter "on them"i
                 | "with"i counter "on it"i
                 | "with"i counter_type "counters on them"i
                 | "with"i counter_type "counters on it"i

// Spell type descriptions (for cost reduction patterns)
spell_type_desc: "Instant and sorcery spells"i
               | "Creature spells"i
               | "Noncreature spells"i
               | color "spells"i
               | permanent_type "spells"i
               | creature_type "spells"i
               | creature_type "spells and"i creature_type "spells"i

// Optional suffix for stat modifiers
stat_modifier_suffix: ("as long as"i condition_clause)?
                    | "and"i ("have"i | "gain"i | "gains"i | "has"i) ability_granted duration?
                    | "and must be blocked this turn if able"i
                    | duration "and must be blocked this turn if able"i

// Optional reminder text suffix
reminder_suffix: "."? reminder_text?

// Duration for effects
duration: "until end of turn"i | "until your next turn"i | "this turn"i | "until the end of your next turn"i
        | "for the rest of the game"i

// Where clause (for X variables): "where X is this creature's power"
where_clause: "," "where X is"i /[^.]+/

// Type addition (gaining a creature type)
type_addition: "a"i creature_type "in addition to its other types"i
             | "an"i creature_type "in addition to its other types"i

// Untap timing for "doesn't untap" effects
untap_timing: "your untap step"i | "its controller's untap step"i

// ==================== SPELL COST MODIFICATIONS ====================
// Cost modification for spells
spell_cost_modification: "This spell costs"i cost_modifier
                       | "This spell costs"i "{" NUMBER "}" cost_direction "for each"i entity
                       | "This spell costs"i "{" NUMBER "}" cost_direction "for each"i card_type "card in"i zone
                       | "This spell costs"i "{X}"i cost_direction "," "where X is"i cost_reference
                       | "This spell has"i ability_granted
                       // Additional cost
                       | "As an additional cost to cast this spell"i "," additional_cost_action

// Cost modifiers
cost_modifier: "{" NUMBER "}" cost_direction condition?
             | "{" NUMBER "}" cost_direction "if it targets"i target_condition_desc

// Cost direction
cost_direction: "less to cast"i | "more to cast"i

// Target condition descriptions (for cost modifiers)
target_condition_desc: "a tapped creature"i
                     | "an untapped creature"i
                     | "a creature"i
                     | "a player"i

// Cost reference for "where X is" patterns
cost_reference: "the total power of"i entity
              | "the number of"i entity

// Additional cost actions
additional_cost_action: "sacrifice"i sacrifice_target
                      | "discard"i NUMBER "card"i NUMBER?
                      | "pay"i mana_cost
                      | "sacrifice"i sacrifice_target "or pay"i mana_cost
                      | "exile"i exile_target

// ==================== ENTERS ABILITIES ====================
// Consolidated enters abilities
enters_ability: entity "enters"i enters_location? enters_condition?
              | permanent_enters_ability
              | entity "enters"i enters_location? counter_condition
              | entity "enters"i counter "on it"i for_each_clause?
              | entity "enters"i "an additional"i counter_type "counter on it"i for_each_clause
              // "~ enters X +1/+1 counters on it" (variable counters)
              | entity "enters"i NUMBER counter_type "counters on it"i for_each_clause?
              | entity "enters"i NUMBER counter_type "counters on it"i where_clause
              // "~ enters a counter on it if condition"
              | entity "enters"i counter "on it if"i condition_clause

// Permanent enters ability (for lands and artifacts)
permanent_enters_ability: permanent_self enters_condition_simple? "."?

// Self-referential permanent
permanent_self: "This land"i | "This artifact"i

// Simplified enters condition for permanent_enters_ability
enters_condition_simple: "enters"i enters_location_simple? enters_with_counters?
                       | "enters"i enters_location_simple? "tapped"i

// Simplified enters location
enters_location_simple: "the battlefield"i

// Where the entity enters
enters_location: "the battlefield"i enters_controller?

// Controller of the entering entity
enters_controller: "under"i entity "control"i

// Condition of entering (tapped, with counters, etc.)
enters_condition: "tapped"i
                | "with"i counter_amount? counter counter_placement
                | enters_controller? "with"i counter_amount? counter counter_placement
                | enters_controller? "tapped"i
                | "a"i counter "on it"i

// Special counter condition
counter_condition: "eight"i counter_type "counters on it if you cast it"i

// Enters with counters
enters_with_counters: "with"i counter_amount? counter_type counter_suffix

// Counter suffix (singular or plural)
counter_suffix: "counter on it"i | "counters on it"i

// Counter placement
counter_placement: "on it"i | "counters on it"i

// Counter amount (optional)
?counter_amount: NUMBER | "one"i | "two"i | "three"i | "four"i | "five"i | "six"i | "seven"i | "eight"i

// ==================== AS ENTERS ABILITIES ====================
// Abilities that trigger as a permanent enters the battlefield
as_enters_ability: "As"i entity enters_battlefield "," as_enters_effect

// Enters battlefield phrase
enters_battlefield: "enters"i | "enters the battlefield"i

// Effect for as_enters_ability
as_enters_effect: choose_effect | effect | compound_effect

// Choose effect
choose_effect: choose_verb choice_target

// Choose verb
choose_verb: "choose"i | "you may choose"i

// Choice target
choice_target: "a"i choice_type
             | "any card name"i

// Choice types
choice_type: "color"i
           | "creature type"i
           | permanent_type "type"i

// ==================== IF WOULD ABILITIES ====================
// Replacement effects
if_would_ability: "If"i would_condition "," replacement_effect
                // "If an effect would" patterns (doubling effects)
                | "If an effect would"i /[^,]+/ "," /[^.]+/

// Would conditions
would_condition: // Graveyard/death related
               | "~"i "would be put into a graveyard from anywhere"i
               | entity "would" "die"i
               | entity "would" "be destroyed"i

               // Damage related
               | "damage would be dealt to"i entity
               | entity "would" "deal damage"i
               | "a creature you control would deal damage to a permanent or player"i
               | "a source you control would deal damage to an opponent or a permanent an opponent controls"i

               // Life gain related
               | "you would"i "gain life"i
               | "you would gain life"i

               // Zone change related
               | entity "would" "enter the battlefield"i

               // Card type would die/be destroyed
               | ("a"i | "an"i) card_type "or"i card_type "card would"i ("die"i | "be destroyed"i)
               | ("a"i | "an"i) card_type "card would"i ("die"i | "be destroyed"i)

               // Other actions
               | entity "would" action

// Replacement effect
replacement_effect: // Library replacement
                  | "reveal"i "~"i "and"i "shuffle"i "it"i "into"i "its owner's library"i "instead"i "."?

                  // Exile replacement
                  | "exile"i entity "instead"i "."?

                  // Damage prevention
                  | "prevent"i "that"i "damage"i "."?
                  | "prevent"i NUMBER "of"i "that"i "damage"i "."?
                  | "that"i "damage"i "can't"i "be"i "prevented"i "."?

                  // Life gain replacement
                  | "you gain that much life plus"i NUMBER "instead"i

                  // Damage doubling
                  | "it deals double that damage instead"i

                  // Generic replacements
                  | effect "instead"i "."?
                  | entity action "instead"i "."?

// ==================== MODAL ABILITIES ====================
// Modal abilities with choices
modal_ability: modal_choice choice_separator NEWLINE? modal_options?
             | choose_one_ability

// Modal choice type
modal_choice: "Choose one"i | "Choose one or more"i | "Choose two"i
            | "choose one that hasn" APOSTROPHE "t been chosen"i

// Modal options
modal_options: modal_option+

// Modal option
modal_option: modal_bullet modal_effect NEWLINE?

// Modal bullet point
modal_bullet: "•"i | BULLET | "—"

// Modal effect types
modal_effect: // General effects
            | effect "."?

            // Compound effects in modal options
            | compound_effect "."?

            // Damage effects
            | entity "deals"i NUMBER "damage to target"i damage_target "."?

            // Ability granting effects
            | entity_grant ("gains"i | "gain"i) ability_granted duration? "."?
            | "Target"i entity "gains"i ability_granted duration? "."?
            | "Target creature gains"i ability_granted duration? "."?
            | "Permanents you control gain"i ability_granted duration? "."?

            // Conditional modal effects
            | create_effect "if"i condition_clause "."?
            | effect "if"i condition_clause "."?

// ==================== CHOOSE ONE ABILITY ====================
// Choose one ability (triggered version)
choose_one_ability: trigger_prefix? modal_choice choice_separator? choose_one_options?

// Trigger prefix for choose_one_ability
trigger_prefix: trigger_condition ","

// Choose one options (reuses modal_option for bullet + effect patterns)
choose_one_options: NEWLINE modal_option+

// Choice separator
choice_separator: "—" | "--" | "-" | ":"

// ==================== CHARACTERISTIC DEFINING ABILITIES ====================
// Abilities that define characteristics of a permanent

// Possessive ability (for handling ~'s power and toughness)
possessive_ability: entity APOSTROPHE "s" possessive_property

// Possessive properties - grouped by type
possessive_property: // Power and toughness together
                   | "power and toughness are each equal to" stat_reference

                   // Power only
                   | "power is equal to" stat_reference

                   // Toughness only
                   | "toughness is equal to" stat_reference

// Stat reference (used for power/toughness equal-to expressions)
stat_reference: entity
              | "the number of" entity "you control"
              | "the number of" entity "in"i zone
              | "your life total"
              | NUMBER "plus the number of" entity "you control"
              // "cards in your opponents' graveyards", "instant and sorcery cards in your graveyard"
              | card_type? "cards in"i zone
              | card_type "and"i card_type "cards in"i zone

// Identity ability
identity_ability: entity identity_verb identity_description
                 // Contraction "It's" = "It is"
                 | "It" APOSTROPHE "s"i identity_description

// Identity verb
identity_verb: "is" | "becomes"

// Identity descriptions - grouped by type
identity_description: // Type changing
                    | "the chosen type in addition to its other types"
                    | "a" permanent_type "in addition to its other types"
                    | "a"i creature_type "in addition to its other types"i
                    | "still a"i permanent_type

                    // Color changing
                    | color "in addition to its other colors"

                    // Copy effects
                    | "a copy of" entity

                    // Creature transformation
                    | "a" NUMBER "/" NUMBER color? creature_type+
                    | "a" NUMBER "/" NUMBER color? creature_type+ "with" ability_granted
                    | "a" NUMBER "/" NUMBER color? creature_type+ "until end of turn"

// ==================== MECHANIC-SPECIFIC ABILITIES ====================
// ===== WARD =====
// Ward ability
ward_ability: "Ward"i ward_separator ward_cost ward_reminder?

// Ward separator
ward_separator: "—" | " "

// Ward costs - consolidated
ward_cost: mana_cost
         | "Pay" NUMBER "life"i
         | "Discard a card"i
         | "Sacrifice a" permanent_type
         | "{" NUMBER "}"
         // Compound ward costs: "{3}, Pay 3 life"
         | mana_cost "," "Pay"i NUMBER "life"i
         | "{" NUMBER "}" "," "Pay"i NUMBER "life"i
         | NUMBER "life"i
         // Compound ward cost: "{3}, Pay 3 life"
         | "{" NUMBER "}" "," "Pay"i NUMBER "life"i

// Ward reminder
ward_reminder: "(" "Whenever this creature becomes the target of a spell or ability an opponent controls, counter it unless that player"i ward_payment "."? ")"

// Ward payment
ward_payment: "pays"i ("{" NUMBER "}" | NUMBER "life")

// ===== CHANGELING =====
// Changeling ability
changeling_ability: "Changeling"i (changeling_reminder | reminder_text)?

// Changeling reminder
changeling_reminder: "(" "This card is every creature type." ")"

// ===== HEXPROOF FROM =====
// Hexproof from ability
hexproof_from_ability: "Hexproof from"i hexproof_from_target hexproof_from_reminder?

// Hexproof from target
hexproof_from_target: color
                    | "instants"i
                    | "sorceries"i
                    | "instants and sorceries"i
                    | permanent_type

// Hexproof from reminder
hexproof_from_reminder: "(" "This creature can't be the target of"i color "spells or abilities your opponents control." ")"
                      | "(" "This creature has hexproof from"i color "spells or abilities your opponents control." ")"

// ===== CREW =====
// Crew ability
crew_ability: "Crew"i NUMBER crew_reminder?

// Crew reminder
crew_reminder: "("i "Tap any number of creatures you control with total power"i NUMBER "or more"i ":" "This Vehicle becomes an artifact creature until end of turn."i ")"i

// ===== EQUIP =====
// Equip ability
equip_ability: "Equip"i equip_cost reminder_text?

// Equip cost - consolidated
equip_cost: mana_cost
          | "{" mana_cost "}" "(" mana_cost ":" equip_reminder ")"

// Equip reminder
equip_reminder: "Attach to target creature you control. Equip only as a sorcery."i

// ===== ENCHANT =====
// Enchant keyword (defines what the Aura can enchant)
enchant_ability: "Enchant"i enchant_target

// Enchanted ability (continuous effects on the enchanted permanent)
enchanted_ability: "Enchanted"i enchant_target enchanted_effect
                 // "You control enchanted permanent" pattern
                 | "You control enchanted"i enchant_target
                 // "Enchanted X gains QUOTED_TEXT" (enchanted land/creature gains an ability)
                 | "Enchanted"i enchant_target "gains"i QUOTED_TEXT

// Enchanted effect
enchanted_effect: "gets"i stat_modifier enchanted_suffix?
                | "has"i ability_granted reminder_text?
                // Type transformation: "is a colorless land with ... and loses all other card types and abilities"
                | "is a"i /[^.]+/ "and loses all other card types and abilities"i
                // Restriction: "can't attack or block"
                | "can't"i action
                // Loses abilities and gains type
                | "loses all abilities and"i /[^.]+/ reminder_text?

// Enchanted suffix (optional modifier after stat_modifier)
enchanted_suffix: "and"i ("has"i | "gains"i) (ability_granted | keyword) reminder_suffix?
                | "for each"i entity
                | "," "has"i ability_granted "," "and gains"i type_addition

// Enchant target - grouped by type
enchant_target: "player"i
              | permanent_type
              | color permanent_type
              | combined_type
              // Qualified types
              | permanent_type "with"i ability_granted
              | permanent_type "with"i stat_condition

// Stat condition
stat_condition: stat_condition_type comparison_operator NUMBER
             | stat_condition_type NUMBER "or less"i
             | stat_condition_type NUMBER "or greater"i

// Creature stats for stat conditions
stat_condition_type: "power"i | "toughness"i | "mana value"i

// Comparison operators
comparison_operator: // Text operators
                   | "greater than"i
                   | "less than"i
                   | "equal to"i
                   | "greater than or equal to"i
                   | "less than or equal to"i

                   // Symbol operators
                   | ">" | "<" | "=" | ">=" | "<="

// ===== LAND ABILITIES =====
// Land abilities
land_ability: // Basic mana abilities
            | "{T}" ":" "Add"i mana_production

            // Activated abilities
            | "{" NUMBER "}" "," "{T}" land_activation_suffix? ":" effect

            // Mana with restriction
            | "{T}" ":" "Add"i mana_production "." mana_spend_restriction

// Mana production
mana_production: // Single mana
               | mana_symbol ("or" mana_symbol)*
               | "{" color_symbol "}" ("or"i "{" color_symbol "}")?
               | "{" color_symbol "}" ("{" color_symbol "}")*
               | "{C}{C}" "."?

               // Any mana
               | "one mana of any color"i "."?
               | "one mana of the chosen color"i "."?
               | "two mana of any one color"i "."?
               | "three mana of any one color"i "."?

               // Variable mana
               | "{" color_symbol "}" "for each"i entity

// Mana spend restriction
mana_spend_restriction: "Spend this mana only to cast"i spell_type_restriction
                      | "Spend this mana only to cast"i spell_type_restriction "or activate"i activation_restriction_target

// Spell type restriction for mana spending
spell_type_restriction: "a"i creature_type "spell"i
                      | "an"i creature_type "spell"i
                      | "a creature spell of the chosen type"i
                      | "a"i color "spell"i

// Activation restriction target for mana spending
activation_restriction_target: "an ability of a creature source of the chosen type"i
                             | "an ability of"i entity

// Land activation suffix
land_activation_suffix: "," land_action
                      | "," "Sacrifice this artifact"

// Land actions
land_action: "Return this land to its owner's hand"i
           | "Sacrifice this land"i
           | "Tap another untapped land you control"i

// ==================== NAMED MECHANIC ABILITIES ====================

// ===== LANDFALL =====
// Landfall ability
landfall_ability: "Landfall"i "—"i landfall_effect

// Landfall effect
landfall_effect: landfall_trigger "," landfall_resolution

// Landfall trigger
landfall_trigger: "Whenever a land you control enters"i
                | "Whenever a land enters the battlefield under your control"i

// Landfall resolution
landfall_resolution: optional_may? (effect | choose_one_ability | compound_effect)

// ===== THRESHOLD =====
// Threshold ability
threshold_ability: "Threshold"i "—"i threshold_effect

// Threshold condition
threshold_condition: "as long as there are seven or more cards in your graveyard"i
                   | "if there are seven or more cards in your graveyard"i

// Threshold effect - grouped by type
threshold_effect: // Static effects
                | entity "gains"i ability_granted threshold_condition
                | "This creature gets"i stat_modifier threshold_condition
                // Compound stat + ability: "gets +1/+1 and gains deathtouch as long as..."
                | "This creature gets"i stat_modifier "and gains"i ability_granted threshold_condition

                // Triggered effects
                | "Whenever this creature attacks"i "," threshold_condition "," effect
                | "Whenever"i entity "attacks"i "," threshold_condition "," effect

                // Special effects
                | "if you attacked this turn"i "," threshold_special_effect

// Threshold special effect
threshold_special_effect: "look at the top three cards of your library"i "." "You may put one of those cards back on top of your library"i "." "Put the rest into your graveyard"i

// ===== FLASHBACK =====
// Flashback ability
flashback_ability: "Flashback"i flashback_cost flashback_reminder?

// Flashback cost - consolidated
flashback_cost: mana_cost | "{" mana_cost "}"

// Flashback reminder
flashback_reminder: "(" flashback_reminder_text ")"
                  | reminder_text

// Flashback reminder text
flashback_reminder_text: "You may cast this card from your graveyard for its flashback cost. Then exile it."i
                       | "You may cast that card from your graveyard for its flashback cost. Then exile it."i

// ===== SURVEIL =====
// Surveil ability
surveil_ability: surveil_standalone
               | surveil_activated
               | surveil_triggered

// Standalone surveil
surveil_standalone: "Surveil"i NUMBER surveil_reminder?

// Activated surveil
surveil_activated: "{T}"i ":" "Surveil"i NUMBER surveil_reminder?

// Triggered surveil
surveil_triggered: "Whenever you gain life for the first time each turn"i "," "surveil"i NUMBER surveil_reminder?

// Surveil reminder
surveil_reminder: "(" surveil_reminder_text ")"

// Surveil reminder text
surveil_reminder_text: "Look at the top"i NUMBER "cards of your library"i "," "then put any number of them into your graveyard and the rest on top of your library in any order"i "."?
                     | reminder_text

// ===== MILL =====
// Mill ability
mill_ability: mill_standalone
            | mill_target
            | mill_compound

// Standalone mill
mill_standalone: "Mill"i NUMBER "cards"i mill_reminder?

// Target mill
mill_target: entity "mills"i NUMBER "cards"i mill_reminder?

// Compound mill effect
mill_compound: "Mill three cards"i "," "then return an instant or sorcery card from your graveyard to your hand"i

// Mill reminder
mill_reminder: "(" mill_reminder_text ")"

// Mill reminder text
mill_reminder_text: "Put the top"i NUMBER "cards of your library into your graveyard"i "."?
                  | reminder_text

// ===== RAID =====
// Raid ability
raid_ability: "Raid"i "—"i raid_effect

// Raid condition
raid_condition: "if you attacked this turn"i

// Raid effect - grouped by type
raid_effect: // Enters battlefield effects
           | "When"i entity "enters"i "," raid_condition "," effect
           | "When"i entity "enters"i "," raid_condition "," compound_effect
           | "When this creature enters"i "," raid_condition "," entity "deals"i NUMBER "damage to any target"i
           | "This creature enters"i counter "on it if you attacked this turn"i

           // Compound enters raid effects
           | "When this creature enters"i "," raid_condition "," compound_effect

           // End step effects
           | "At the beginning of your end step"i "," raid_condition "," effect
           | "At the beginning of your end step"i "," raid_condition "," compound_effect

// ===== MORBID =====
// Morbid ability
morbid_ability: "Morbid"i "—"i morbid_effect

// Morbid condition
morbid_condition: "if a creature died this turn"i

// Morbid effect - grouped by type
morbid_effect: // Enters battlefield effects
             | "When this creature enters"i "," morbid_target_effect

             // End step effects
             | "At the beginning of each end step"i "," morbid_condition "," effect
             | "At the beginning of your end step"i "," morbid_condition "," effect

             // Modal (choose one) effects
             | "At the beginning of your end step"i "," morbid_condition "," modal_choice choice_separator choose_one_options?

// Morbid target effect
morbid_target_effect: "target creature an opponent controls gets"i stat_modifier "until end of turn"i "." morbid_condition "," "that creature gets"i stat_modifier "instead"i

// ==================== PLANESWALKER ABILITIES ====================
// Planeswalker ability (one or more loyalty abilities)
planeswalker_ability: loyalty_ability+

// Loyalty ability
loyalty_ability: loyalty_cost ":" planeswalker_effect

// Loyalty cost
loyalty_cost: "[" loyalty_value "]"

// Loyalty value
loyalty_value: "+" NUMBER  // Positive loyalty
             | "−" NUMBER  // Negative loyalty (en dash)
             | "-" NUMBER  // Negative loyalty (hyphen)
             | "0"         // Zero loyalty

// Planeswalker effect types
planeswalker_effect: // General effects
                   | effect
                   // Complex choice effects
                   | entity "chooses"i /[^.]+/

                   // Token creation
                   | "Create"i token

                   // Mana and exile effects
                   | "Add"i mana_symbol mana_symbol mana_symbol "."? exile_top_effect

                   // Damage effects
                   | entity "deals"i NUMBER "damage divided as you choose among any number of target"i entity
                   | entity "deals"i NUMBER "damage divided as you choose among any number of target"i target_description "and/or"i target_description

                   // Ability granting effects
                   | "Up to one target creature"i "you control"i? "gains"i ability_granted "this turn"i "."? effect
                   | "Up to one target creature"i "you control"i? "gains"i ability_granted duration? "."? effect?

                   // Emblem effects
                   | "You get an emblem with"i QUOTED_TEXT
                   // Emblem with unclosed quote (data issue - some emblems have unclosed quotes)
                   | "You get an emblem with"i "\"" /[^"]+/

                   // Compound planeswalker effects
                   | compound_effect
                   | add_mana_effect "."? exile_top_effect
                   | create_effect

// Exile top effect
exile_top_effect: "Exile the top"i NUMBER "cards of your library"i "." "Choose one"i "." "You may play that card this turn"i
               | "Exile the top"i NUMBER "cards of your library"i "." "Choose one"i "." "You may play that card this turn"i "."?

// ==================== EFFECTS ====================
// Effects - main categories
effect: // Creation effects
      | create_effect

      // Card manipulation effects
      | draw_effect
      | discard_effect
      | search_effect
      | shuffle_effect
      | look_effect
      | reveal_until_effect

      // Life and damage effects
      | life_change_effect
      | damage_effect
      | prevent_effect

      // Permanent manipulation effects
      | destroy_effect
      | exile_effect
      | return_effect
      | tap_effect
      | transform_effect
      | modify_creature_effect
      | put_counter_effect
      | attach_effect
      | sacrifice_effect

      // Spell manipulation effects
      | counter_effect
      | copy_effect

      // Zone change effects
      | enters_effect

      // Keyword action effects
      | mill_effect
      | surveil_effect
      | scry_effect

      // Mana production effects
      | add_mana_effect

      // Counter manipulation effects
      | double_counter_effect
      | remove_counter_effect
      | distribute_effect

      // Creature transformation effects
      | become_creature_effect

      // Fight effects
      | fight_effect

      // Complex effects
      | conditional_effect
      | compound_effect
      | may_effect

      // Restriction effects (entity can't do something)
      | restriction_effect

      // Simple effects
      | simple_effect

// ==================== SIMPLE EFFECTS ====================
// Simple effect patterns (damage moved to damage_effect)
simple_effect: // Information patterns
             | reveal_effect
             | reveal_hand_effect

             // Control patterns
             | control_effect

             // Special game effects
             | "End the turn"i
             | "Choose one of them"i
             | "You lose the game"i
             | "You win the game"i
             | "After this phase, there is an additional combat phase"i
             | "You may choose new targets for the copies"i
             | "You may choose new targets for the copy"i

             // Target change patterns
             | change_target_effect

             // Choose effects (name, color, type)
             | choose_effect

             // Player state changes (usable as effects in compound effects)
             | "you have no maximum hand size"i duration?
             | "Until end of turn"i "," "you don't lose this mana as steps and phases end"i

             // Owner library placement
             | "Target"i target_description APOSTROPHE "s owner puts it on their choice of the top or bottom of their library"i

             // Cost definition effects
             | "The flashback cost is equal to that card" APOSTROPHE "s mana cost"i

// Restriction effect (entity can't do action, used as an effect in activated/triggered abilities)
restriction_effect: (target | "Players"i) "can't"i action duration?

// Damage amount
damage_amount: NUMBER "damage"i
             | "damage equal to"i entity
             | "damage equal to its power"i
             | NUMBER "damage to its power"i
             | "damage equal to"i entity APOSTROPHE "s"i creature_stat

// Damage target
damage_target: target
             | "each"i entity
             | "each opponent"i
             | "target"i entity
             | "any target"i
             | "target player or planeswalker"i
             | "each player or planeswalker"i
             | "each of up to"i NUMBER "other targets"i
             | "each creature without"i ability_granted
             | "each creature with"i ability_granted

// Change target effect
change_target_effect: "Change the target of target spell or ability with a single target"i

// Reveal effect
reveal_effect: entity "reveals"i entity
             | library_reveal_effect
             | "look at"i entity APOSTROPHE "s hand"i
             // "Reveal the top X cards of your library. You may put..."
             | "Reveal the top"i NUMBER "cards of your library"i "." reveal_top_action "." reveal_top_rest

// Reveal top cards actions (used by "Reveal the top X cards...")
reveal_top_action: "You may put any number of"i reveal_top_card_desc "from among them onto the battlefield"i
                 | "You may put"i reveal_top_card_desc "from among them into your hand"i

// Card descriptor for reveal-top effects
reveal_top_card_desc: card_type "cards"i reveal_top_filter?
                    | permanent_type "cards"i reveal_top_filter?
                    | "creature cards"i reveal_top_filter?

// Filter for reveal-top card descriptions
reveal_top_filter: "with mana value"i NUMBER "or less"i
                 | "with mana value"i comparison_operator NUMBER

// What to do with the rest of the revealed cards
reveal_top_rest: "Then put all cards revealed this way that weren't put onto the battlefield into your graveyard"i
               | "Put the rest on the bottom of your library in a random order"i
               | "Put the rest into your graveyard"i

// Reveal hand effect (discard after reveal)
reveal_hand_effect: "Target opponent reveals their hand"i "." "You choose a"i card_type "card from it"i "." "That player discards that card"i
                  | "Target opponent reveals their hand"i "." "You choose a"i card_type "card from it"i "." entity "discards that card"i

// Library reveal effect
library_reveal_effect: "look at the top"i NUMBER "cards of your library and separate them into a face-down pile and a face-up pile"i "." "An opponent chooses one of those piles"i "." "Put that pile into your hand and the other into your graveyard"i

// Control effect
control_effect: entity "gains control of"i target
              | entity "gains control of"i entity
              | "gain control of"i target duration?

// ==================== SPECIFIC EFFECT TYPES ====================
// Create effect
create_effect: "create"i token
             | "create"i token_copy
             | entity "creates"i token
             // "For each X, create Y"
             | for_each_clause "," "create"i token
             | for_each_clause "," "you create"i token

// Token copy
token_copy: "a token that's a copy of"i token_copy_target token_copy_exception? token_copy_suffix?

token_copy_target: target

token_copy_exception: "," "except it has"i ability_granted "and"i QUOTED_TEXT

token_copy_suffix: "."? "If this spell was kicked"i "," "create five of those tokens instead"i

// Draw effect
draw_effect: draw_verb NUMBER? "card"i NUMBER?
           | draw_verb NUMBER "cards"i
           | entity draw_verb NUMBER? "card"i NUMBER?
           | entity draw_verb NUMBER "cards"i
           | "you draw a card and you lose"i NUMBER "life"i
           | "draw a card"i for_each_clause
           // "draws an additional card" / "draw cards equal to"
           | entity "draws an additional card"i
           | "draw"i "cards equal to"i entity
           | "draw"i "cards equal to its"i creature_stat
           // "draw a card for each X"
           | "draw"i NUMBER? "card"i for_each_clause
           | "draw"i NUMBER "cards"i for_each_clause

// Draw verb
draw_verb: "draw"i | "you draw"i | "draws"i

// Life change effect
life_change_effect: life_change_verb NUMBER "life"i for_each_clause?
                  | "each opponent loses"i life_amount life_change_suffix?
                  | entity life_change_verb life_amount where_clause?
                  | entity life_change_verb life_amount "unless"i /[^.]+/
                  | "you gain that much life"i

// Suffix for "each opponent loses" pattern
life_change_suffix: "unless that player"i /[^.]+/
                  | "." "You gain life equal to the life lost this way"i

// Life change verb
life_change_verb: "gain"i | "lose"i | "gains"i | "loses"i | "you gain"i | "you lose"i

// Life amount
life_amount: NUMBER "life"i
           | "one life"i
           | "2 life"i
           | "life equal to"i life_reference

// Life reference
life_reference: entity
              | entity "'s"i creature_stat
              | "that creature's"i creature_stat
              | "the sacrificed creature's"i creature_stat
              | counter_type "counters on"i entity
              | "the life lost this way"i

// Damage effect (consolidated: dealer + verb + amount + "to" + recipient)
damage_effect: entity "deals"i damage_amount "to"i damage_target
             | "deal"i damage_amount "to"i damage_target
             // Damage divided patterns (special case)
             | entity "deals"i NUMBER "damage divided as you choose among any number of target"i /[^.]+/
             // "it deals N damage instead" (used in kicked/conditional effects)
             | entity "deals"i damage_amount "instead"i
             // Multi-target damage: "deals N damage to X and M damage to Y"
             | entity "deals"i damage_amount "to"i damage_target "and"i damage_amount "to"i damage_target

// Destroy effect
destroy_effect: "destroy"i target
              | "destroy all"i target_description
              | "destroy each"i target_description
              | "destroy each"i target_description destroy_qualifier
              | "destroy all"i entity
              | "destroy all"i color entity
              | "destroy target"i entity "or"i entity
              | "destroy target"i permanent_type "," permanent_type "," "or"i permanent_type object_condition?
              | "destroy target"i permanent_type "or"i permanent_type object_condition?
              | "Destroy target"i permanent_type "or"i permanent_type "an opponent controls"i "." "You lose life equal to that permanent's mana value"i
              // "destroy target creature with CONDITION"
              | "destroy target"i target_description object_condition
              // "Destroy target X and all other Y with the same name as that Z"
              | "destroy"i target "and all other permanents with the same name as that permanent"i

// Extended destroy qualifier (for "destroy each X with/whose...")
destroy_qualifier: "with mana value"i /[^.]+/

// Exile effect
exile_effect: "exile"i target exile_until_clause?
            | "exile all"i target_description
            | "exile"i target "from"i zone "with"i counter "on it"i
            | "exile"i "the top"i NUMBER "cards of your library"i
            | "exile"i "the top card of each player's library"i
            | "exile up to"i NUMBER "target"i target_description exile_from_clause? exile_until_clause?
            // Exile a zone (e.g., "exile target player's graveyard")
            | "exile"i "target player" APOSTROPHE "s"i zone_type
            // Exile each opponent's graveyard
            | "exile each opponent" APOSTROPHE "s"i zone_type
            // Exile target X that's COLOR or COLOR
            | "exile"i "target"i target_description "that" APOSTROPHE "s"i color "or"i color
            // Exile all other X
            | "exile all other"i target_description "you control"i
            // Exile all other SUBTYPE tokens you control
            | "exile all other"i creature_type "tokens you control"i
            // Exile target card from a graveyard with condition
            | "exile"i target "from"i zone entity?
            | "exile"i target "from a graveyard that was put there this turn"i

// Optional clauses for exile
exile_from_clause: "from"i zone
                 | "from a single graveyard"i
exile_until_clause: "until"i entity "leaves the battlefield"i

// Search effect
// Search effect (consolidated: search + quantity? + target + action chain)
search_effect: "search"i ("your"i | "their"i) "library for"i search_quantity? search_target ("," search_action)* ("." search_sentence_action)*
             // Special Gate search with win condition
             | "Search your library for a Gate card"i "," "put it onto the battlefield"i "," "then shuffle"i "." "If you control ten or more Gates with different names"i "," "you win the game"i

// Search quantity (optional)
search_quantity: "up to"i NUMBER
               | NUMBER

// Individual search actions (comma-separated)
search_action: "reveal it"i
             | "reveal them"i
             | "put it into your hand"i
             | "and put it into your hand"i
             | "put them into your hand"i
             | "put that card into your graveyard"i
             | put_onto_battlefield_effect
             | "put them onto the battlefield"i tapped?
             | "shuffle"i
             | "shuffle your library"i
             | "then shuffle"i
             | "then put that card on top of it"i
             | "then put that card on top"i
             | "then put them on top in any order"i
             | "then put that card into your hand"i
             | "exile it"i
             | "then shuffle and put that card on top"i

// Sentence-level search actions (period-separated)
search_sentence_action: "Then shuffle your library"i

// ===== LOOK EFFECT =====
// "Look at the top N cards of your library" patterns (multi-sentence)
look_effect: "look at the top"i NUMBER "cards of your library"i "." "You may reveal"i look_reveal_target "from among them and"i look_reveal_action "." look_rest_clause
           // Raid variant: look + put back + rest to graveyard
           | "look at the top"i NUMBER "cards of your library"i "." "You may put one of those cards back on top of your library"i "." "Put the rest into your graveyard"i

// What can be revealed from the look
look_reveal_target: NUMBER card_type "card"i look_target_filter?
                  | "a"i card_type "card"i look_target_filter?
                  | "a"i card_type "or"i card_type "card"i look_target_filter?

// Filters on the reveal target
look_target_filter: "with power"i NUMBER "or less"i
                  | "with mana value"i comparison_operator entity

// What to do with the revealed card
look_reveal_action: "put it into your hand"i
                  | "put it onto the battlefield"i

// What to do with the rest
look_rest_clause: "Put the rest on the bottom of your library in a random order"i
                | "Put the rest on the bottom in a random order"i

// ===== REVEAL UNTIL EFFECT =====
// "Reveal cards from the top of your library until you reveal N TYPE card"
reveal_until_effect: "reveal cards from the top of your library until you reveal"i NUMBER card_type "card"i "." "Put that card into your hand and the rest on the bottom of your library in a random order"i
                   // "each opponent reveals cards from the top of their library until they reveal N TYPE card, then puts those cards into their graveyard"
                   | entity "reveals cards from the top of their library until they reveal"i NUMBER card_type "card"i "," "then puts those cards into their graveyard"i

// Put onto battlefield effect (consolidated: subject + optional control + optional tapped)
put_onto_battlefield_effect: "put"i put_battlefield_subject "onto the battlefield"i under_your_control? tapped?

// Subject of "put onto battlefield"
put_battlefield_subject: "it"i | "that card"i

// "under your control" clause (reusable)
under_your_control: "under your control"i

// Tapped state
tapped: "tapped"i

// Modify creature effect (consolidated: subject + verb pattern + optional combined + duration/reminder/where)
modify_creature_effect: // Subject gets stat [and gains/has ability]
                      | modify_subject_stat stat_modifier modify_stat_combined? duration? reminder_suffix? where_clause?
                      // Subject gains ability [and gets stat]
                      | modify_subject_ability ability_granted modify_ability_combined? duration? reminder_suffix? where_clause?
                      // Equipment has ability
                      | "Equipped creature"i "has"i ability_granted
                      // Type identity
                      | entity "is"i entity "in addition to its other types"i
                      // Duration prefix patterns: "Until end of turn, target creature gets..."
                      | duration "," modify_subject_stat stat_modifier modify_stat_combined? reminder_suffix?
                      | duration "," modify_subject_ability ability_granted modify_ability_combined? reminder_suffix?
                      // Special cases
                      | "instead"i "any number of target creatures you control gain"i ability_granted duration?
                      | "Double target creature's power"i duration?

// Subjects that use "get/gets" + stat_modifier
modify_subject_stat: target ("gets"i | "get"i)

// Subjects that use "gain/gains" + ability_granted
modify_subject_ability: "another target"i entity "gains"i
                      | target ("gains"i | "gain"i)

// Optional combined: stat pattern followed by ability grant or restriction
modify_stat_combined: "and"i ("gains"i | "gain"i | "has"i | "have"i) ability_granted
                    | "and must be blocked this turn if able"i

// Optional combined: ability pattern followed by stat grant
modify_ability_combined: "and gets"i stat_modifier

// Return effect (consolidated: return + what + optional from + destination + optional state/timing)
return_effect: // Return target/entity to a zone (with optional battlefield modifiers)
             | "return"i target "to"i zone return_under_control? return_with_clause? timing_clause?
             | "return up to"i NUMBER "other target"i target_description "you control"i "to"i zone
             // "Choose N target X. Return those ..."
             | "Choose"i NUMBER "target"i target_description "controlled by different players"i "." "Return those"i target_description "to their owners" APOSTROPHE "hands"i
             // Return card references from zone to zone/battlefield
             | "return"i return_card_ref "from"i zone "to"i zone
             | "return"i return_card_ref "from"i zone "to the battlefield"i return_under_control? tapped? return_with_clause?
             // Return self from zone
             | "return"i entity "from"i zone "to the battlefield"i tapped?
             // Return all cards
             | "return all"i card_type "cards"i return_filter? "from"i zone "to"i zone
             | "return all"i "attacking creatures to their owner's hand"i
             // Put all cards from graveyards
             | "put all"i card_type "cards from all graveyards onto the battlefield under your control"i
             // Return all nonland permanents X controls
             | "return all"i target_description entity "controls to"i zone

// Card reference for return (target TYPE, target TYPE card, up to N target TYPE cards)
return_card_ref: "target"i card_type
               | "target"i card_type "card"i return_filter?
               | "target"i creature_type card_type "card"i return_filter?
               | "up to"i NUMBER "target"i card_type "cards"i
               | "another target"i "non-"i creature_type card_type "card"i return_filter?
               | "another target"i card_type "card"i return_filter?

// Under whose control the permanent returns
return_under_control: "under"i entity "control"i
                    | "under its owner's control"i

// Return with clause (counter on return, with optional timing)
return_with_clause: "with"i counter "on it"i timing_clause?
                  | "with one fewer"i counter_type "counter on it"i timing_clause?

// Timing clause for delayed effects
timing_clause: "at the beginning of the next end step"i
             | "at the beginning of your next upkeep"i

// Return filter (for return all X cards with condition)
return_filter: "with mana value"i NUMBER "or less"i
             | "with mana value"i NUMBER "or greater"i
             | "with mana value"i comparison_operator NUMBER
             | "with mana value"i comparison_operator entity APOSTROPHE "s"i creature_stat
             | "with mana value"i comparison_operator entity

// Attach effect
attach_effect: "attach"i entity "to"i target
             | "attach it to target creature you control"i

// Prevent effect
prevent_effect: "prevent"i NUMBER? "damage"i
              | "prevent all"i damage_type? "damage that would be dealt to"i target "this turn"i
              | "prevent all"i damage_type? "damage that would be dealt"i "this turn"i

// Sacrifice effect
sacrifice_effect: "sacrifice"i sacrifice_target
                | entity "sacrifices"i sacrifice_target
                | entity "sacrifices"i sacrifice_object
                | sacrifice_prefix entity "sacrifices"i sacrifice_object
                | sacrifice_prefix entity "sacrifices"i half_sacrifice

// Prefix for sacrifice abilities (who is targeted by the sacrifice)
sacrifice_prefix: "Target"i | "Each"i

// Object of sacrifice (what is being sacrificed)
sacrifice_object: sacrifice_target
                | choice_sacrifice
                | NUMBER choice_sacrifice

// Sacrifice with "of their choice" pattern
choice_sacrifice: "a"i permanent_type "of their choice"i
                | "creatures of their choice"i
                | permanent_type "of their choice"i
                | "a creature or planeswalker of their choice"i
                | "creature of their choice"i

// Half sacrifice patterns
half_sacrifice: "half"i "the creatures they control"i "rounded up"i
              | "half"i "the permanents they control"i "rounded up"i
              | "half"i "the"i permanent_type "they control"i "rounded up"i

// Sacrifice ability
sacrifice_ability: sacrifice_prefix? entity "sacrifices"i sacrifice_object

// Discard effect
discard_effect: "discard"i NUMBER? "card"i NUMBER?
              | "discard"i NUMBER "cards"i
              | entity "discards"i NUMBER? "card"i NUMBER?
              | entity "discards"i NUMBER "cards"i
              | entity "discards"i "their hand"i
              | entity "discards"i "a card of their choice"i
              | "each opponent discards a card"i
              | "you discard"i NUMBER "card"i
              | "you discard"i NUMBER "cards"i
              // "discard N card unless condition"
              | "discard"i NUMBER "card"i "unless"i condition_clause
              | "discard"i NUMBER "cards"i "unless"i condition_clause

// Shuffle effect
shuffle_effect: "shuffle"i
              | "shuffle your library"i
              | "shuffle your graveyard into your library"i

// Tap effect
tap_effect: "tap"i target
          | "untap"i target
          | "untap up to"i NUMBER "target"i target_description
          | "untap up to"i NUMBER entity
          | "tap up to"i NUMBER "target"i target_description

// Transform effect
transform_effect: "transform"i target

// Counter effect
counter_effect: "counter"i "target"i "spell"i
              | "counter"i "target"i card_type "spell"i
              | "counter"i "target"i "spell or ability"i
              | "counter target"i spell_type
              | "counter"i entity
              | "counter target"i color "spell"i
              | "counter target"i color "or"i color "spell"i
              | "counter target"i card_type "or"i card_type "spell"i

// Copy effect
copy_effect: "copy"i "target"i "spell"i
           | "copy"i "target"i card_type "spell"i
           | "copy"i entity
           | "copy target"i spell_type
           // "copy it for each other X spell you've cast before it this turn"
           | "copy"i entity "for each other"i /[^.]+/ "this turn"i

// Enters effect (consolidated: optional battlefield + optional control + optional state)
enters_effect: "enters"i enters_battlefield_clause? enters_control_clause? enters_state_clause?

// "the battlefield" destination
enters_battlefield_clause: "the battlefield"i

// "under X's control" clause
enters_control_clause: "under"i entity "control"i

// State on entry (tapped or with counter)
enters_state_clause: "tapped"i
                   | "with"i counter "on it"i
                   | "with"i NUMBER counter "on it"i

// Mill effect
mill_effect: "mill"i NUMBER "cards"i
           | entity "mills"i NUMBER "cards"i

// Surveil effect
surveil_effect: "surveil"i NUMBER reminder_text?

// Scry effect
scry_effect: "scry"i NUMBER reminder_text?

// Add mana effect (mana production as an effect)
add_mana_effect: "Add"i mana_production
               | "add"i mana_production

// Remove counter effect
remove_counter_effect: "remove"i counter "from"i entity

// Double counter effect
double_counter_effect: "double the number of"i counter_type "counters on"i entity
                     | "double the number of each kind of counter on"i entity
                     | "double the number of each kind of counter on up to"i NUMBER "target"i entity
                     | "double the number of each kind of counter on up to"i NUMBER "target"i /[^.]+/

// Distribute counters effect
distribute_effect: "Distribute"i NUMBER counter_type "counters among"i /[^,.]+/ "target"i target_description

// Fight effect (creature fights another creature)
fight_effect: target "fights"i target
            | entity "fights"i target
            | entity "fights"i entity
            | target "fights"i entity
            | "it fights up to"i NUMBER "target"i target_description reminder_text?

// Become creature effect (land/artifact animation)
become_creature_effect: entity "becomes a"i NUMBER "/" NUMBER entity "with"i ability_granted "and all creature types"i still_clause?
                      | entity "becomes a"i NUMBER "/" NUMBER entity "with"i ability_granted still_clause?
                      | entity "becomes a"i NUMBER "/" NUMBER color? creature_type? "creature"i become_creature_suffix? still_clause?
                      | entity "becomes a"i creature_type
                      | entity "becomes a copy of"i entity become_copy_suffix?

// "It's still a land" clause (used after animation effects)
still_clause: "." "It" APOSTROPHE "s still a"i permanent_type

// Suffix for become creature effects
become_creature_suffix: "with"i ability_granted ("and all creature types"i)?
                      | "until end of turn"i

// Suffix for become copy effects
become_copy_suffix: "except"i token_exception

// Put counter effect
put_counter_effect: "put"i counter "on"i target
                  | "put a"i counter_type "counter on"i entity
                  | "put"i NUMBER counter_type "counters on"i entity
                  | "put"i counter "on each of up to"i NUMBER "other target"i entity
                  | "put"i counter "on each of up to"i NUMBER "target"i entity
                  | "put"i NUMBER counter_type "counters on"i target
                  // "up to N target" patterns
                  | "put"i counter "on up to"i NUMBER "target"i entity
                  | "put"i counter "on up to"i NUMBER "target"i target_description
                  // Put that many counters
                  | "put that many"i counter_type "counters on"i entity
                  | "put that many"i counter_type "counters on"i target
                  // Put X counters with where clause
                  | "put"i NUMBER counter_type "counters on"i entity where_clause
                  | "put"i NUMBER counter_type "counters on"i target where_clause
                  // Put counter for each X
                  | "put"i counter "on"i entity for_each_clause

// Conditional effect
conditional_effect: "if"i condition_clause "," effect
                  | "if"i condition_clause "," compound_effect
                  | "if you do"i "," effect
                  | "if you do"i "," compound_effect
                  | "if you control ten or more Gates with different names"i "," "you win the game"i
                  // Kicker conditionals
                  | "If this spell was kicked"i "," "instead"i effect
                  | "If this spell was kicked"i "," "instead"i compound_effect
                  | "If this creature was kicked"i "," entity "enters"i enters_condition
                  // "If X is N or more, instead..."
                  | "If X is"i NUMBER "or more"i "," "instead"i compound_effect

// Compound effect (multiple effects joined by "and", "then", or periods)
compound_effect: effect "and" effect
               | effect "," "then" effect
               | effect "." effect
               | effect "." "Then"i effect
               | effect "and" compound_effect
               | effect "." compound_effect
               | effect "." "Then"i compound_effect

// May effect
may_effect: "you may"i may_action

// May action (what can be done with "you may")
may_action: "put"i entity "onto the battlefield"i
          | "put"i entity "into"i zone
          | "cast"i entity
          | "cast any number of spells from among those cards without paying their mana costs"i
          | "cast"i target entity "from"i zone duration?
          | "cast"i "target"i creature_type? card_type "card from"i zone duration?
          | "play"i entity
          | "play that card"i duration?
          | "pay"i mana_cost
          | "return"i entity "to your hand"i
          | "return"i "another"i card_type "card from"i zone "to"i zone
          | "search your library for"i search_target
          | "sacrifice"i sacrifice_target
          | "discard"i NUMBER? "card"i NUMBER?
          | "exile"i entity
          | "tap"i entity
          | "untap"i entity
          | "transform"i entity
          | "reveal"i entity
          | "put"i counter "on"i entity
          | "put"i NUMBER counter "on"i entity
          | "copy"i entity
          | "choose"i entity
          | "look at the top"i NUMBER "cards of your library"i
          | "mill"i NUMBER "cards"i
          | "surveil"i NUMBER
          | "counter target"i spell_type
          | "gain"i NUMBER "life"i
          | "lose"i NUMBER "life"i
          | "create"i token
          | "deal"i NUMBER "damage to"i target
          | "destroy"i target
          | "exile"i target
          | "return"i target "to"i zone
          | "attach"i entity "to"i target
          | entity "gain"i ability_granted
          | entity "get"i stat_modifier "until end of turn"i?
          | "prevent"i NUMBER? "damage"i
          | "draw"i NUMBER? "card"i NUMBER?
          | "have"i entity "fight"i target
          // "you may have target creature get/gain" patterns
          | "have"i target ("get"i stat_modifier | "gain"i ability_granted) duration?
          // "you may have it become a X/X TYPE creature until end of turn"
          | "have"i entity "become a"i NUMBER "/" NUMBER color? creature_type? "creature"i duration?

// Gain life effect
gain_life_effect: "gain"i NUMBER "life"i


// ==================== TOKENS ====================
// Tokens use the object_descriptor system for their core description.
// The object_descriptor handles the ordered characteristics (P/T, color, subtypes, types)
// and ends with "token"/"tokens" via the object_kind layer in obj_type_core.

token: ("a"i | "an"i) object_descriptor token_suffix?
     | ("a"i | "an"i) "tapped"i object_descriptor token_suffix?
     | NUMBER object_descriptor token_suffix?
     | counter_amount object_descriptor token_suffix?
     // Named/legendary tokens: "Scion of the Deep, a legendary 8/8 blue Octopus creature token"
     | /[A-Z][a-zA-Z ]+/ "," ("a"i | "an"i) object_descriptor token_suffix?
     // Copy tokens (unique syntax, not part of object_descriptor)
     | ("a"i | "an"i) "token that's a copy of"i entity ("," "except"i token_exception)?
     | ("a"i | "an"i) "token that's a copy of"i entity ("except"i token_exception)?
     | ("a"i | "an"i) "copy of target"i entity
     | ("a"i | "an"i) "copy of"i entity
     // Variable count tokens (kept as special case due to complex trailing syntax)
     | ("a"i | "an"i) "number of"i object_descriptor "equal to"i entity
     | ("a"i | "an"i) "number of"i object_descriptor "equal to other creatures you control named"i entity

// Optional suffix after the token descriptor
token_suffix: for_each_clause
            | "with"i ability_granted
            | "with"i QUOTED_TEXT
            | "named"i /[^.]+/
            | "," "where X is"i /[^.]+/
            | artifact_token_reminder

// For each clause (reusable)
for_each_clause: "for each"i for_each_subject
               | "for each of"i for_each_subject

// What is being counted in "for each X"
for_each_subject: // Entity or type you control (with optional qualifier)
                | entity
                | entity "in"i zone
                | entity for_each_control
                | creature_type for_each_control
                | basic_land_type for_each_control
                | permanent_type for_each_control
                | "creature you control with"i counter "on it"i
                | "land you control"i
                | "basic"i basic_land_type "you control"i
                | "attacking"i creature_type "you control"i
                | "attacking creature"i
                // Card type references
                | card_type "card in"i zone
                | card_type "card put into a graveyard this way"i
                | "creature destroyed this way"i
                // Counter/value references
                | counter_type "counter on"i entity
                | "different mana value among"i entity
                // Possessive: "that spell's colors", "this creature's power"
                | entity APOSTROPHE "s"i creature_stat
                | entity APOSTROPHE "s colors"i
                // Other/fallback
                | "other"i entity

// Control qualifier for "for each X you control [with ...]"
for_each_control: "you control"i
                | "you already control"i
                | "you control of the chosen type"i
                | "you control with"i counter "on it"i

// Token exceptions
token_exception: "it's"i token_exception_property
               | "it has"i ability_granted
               | "it's"i color
               | "it has"i QUOTED_TEXT
               | "it's"i permanent_type "in addition to its other types"i
               | "it's"i "a"i creature_type "in addition to its other types"i

// Token exception properties
token_exception_property: "a"i NUMBER "/" NUMBER creature_type+
                        | "a"i NUMBER "/" NUMBER color creature_type+
                        | "a"i color creature_type+

// Token reminders
artifact_token_reminder: "(" "It's an artifact with" QUOTED_TEXT ")"

// ==================== REMINDER TEXT ====================
// Standalone reminder text (not attached to a keyword)
reminder_text_only: reminder_text

// Reminder text (in parentheses)
reminder_text: "(" /[^)]+/ ")"
             | "(" QUOTED_TEXT ")"

// ==================== EMPTY LINE ====================
// Empty line (can appear in card text)
empty_line:

// ==================== CONDITIONS ====================
// Conditions
condition: "for each"i entity "you control"i
         | "if"i condition_clause

condition_clause: control_condition
                | life_condition
                | turn_condition
                | cast_condition
                | death_condition
                | opponent_condition
                | battlefield_condition
                | counter_condition_clause
                | identity_condition
                | combat_condition
                | mana_spend_condition
                | resolution_condition

// Control conditions ("you control X")
control_condition: "you control"i entity
                 | "you control"i NUMBER "or more"i entity
                 | "you control"i "a"i color? (permanent_type | creature_type)
                 | "you control"i "another"i (permanent_type | creature_type)
                 | "you control"i ("a"i | "another"i) permanent_type "with"i stat_condition
                 | "you control"i NUMBER "or more"i "lands"i
                 | "you control"i NUMBER "or more"i permanent_type
                 | "you control"i NUMBER "or more"i "Gates with different names"i
                 | "any player controls a"i color permanent_type

// Life and resource conditions
life_condition: "you have"i NUMBER "or more"i entity
              | "you have"i NUMBER "or more"i "cards in your hand"i
              | "you have"i NUMBER "or more"i "cards in your graveyard"i
              | "you have"i NUMBER "or more"i "life"i
              | "you have"i NUMBER "or fewer"i "life"i
              | "you have at least"i NUMBER "life more than your starting life total"i
              | "you've gained"i NUMBER "or more life this turn"i
              | entity "has exactly"i NUMBER "life"i
              | "your life total is greater than your starting life total"i
              | "your life total is at least"i NUMBER "greater than your starting life total"i

// Turn and timing conditions
turn_condition: "it's your turn"i
              | "it's not your turn"i
              | "during your turn"i
              | "you attacked this turn"i

// Casting conditions
cast_condition: "you cast"i spell_type "this turn"i
              | "you've cast"i spell_type "this turn"i
              | "you've cast"i NUMBER "or more"i spell_type "this turn"i
              | "you've cast"i NUMBER "or more instant and sorcery spells this turn"i
              | "you've cast"i "a"i color "spell this turn"i
              | "you've cast"i "another"i "spell this turn"i
              | "you cast it from"i zone
              | "this spell was kicked"i

// Death and graveyard conditions
death_condition: entity "died this turn"i
               | "a creature died this turn"i
               | "a creature you control died this turn"i
               | "a creature an opponent controls died this turn"i
               | "a creature with power"i NUMBER "or greater"i "died this turn"i
               | "an opponent lost life this turn"i
               | "you sacrificed a permanent this way"i
               | "at least one"i card_type "card was exiled this way"i

// Opponent conditions
opponent_condition: "an opponent controls"i entity
                  | "an opponent controls"i NUMBER "or more"i entity
                  | "an opponent has"i NUMBER "or more cards in hand"i
                  | "an opponent has"i NUMBER "or more cards in their graveyard"i
                  | "an opponent has"i NUMBER "or more life"i
                  | "an opponent has"i NUMBER "or fewer life"i

// Battlefield state conditions
battlefield_condition: "there are"i NUMBER "or more"i entity "on the battlefield"i
                     | "there are"i NUMBER "or more cards in your graveyard"i
                     | "there are"i NUMBER "or more instant and/or sorcery cards in your graveyard"i
                     | "a creature with power"i NUMBER "or greater"i "enters the battlefield under your control"i
                     | entity "have total power"i NUMBER "or greater"i

// Counter conditions (on permanents)
counter_condition_clause: entity ("had"i | "has"i) counter "on it"i
                        | entity "has"i NUMBER "or more"i counter "on it"i
                        | entity "has"i NUMBER "or more"i counter_type "counters on it"i

// Resolution/ability timing conditions
resolution_condition: "this is the second time this ability has resolved this turn"i
                    | "this is the first time this ability has resolved this turn"i

// Mana spend conditions
mana_spend_condition: "that mana is spent on"i ("a"i | "an"i) creature_type? card_type? "creature spell"i
                    | "that mana is spent to cast"i ("a"i | "an"i) creature_type? card_type? "spell"i

// Identity conditions (type/color checks)
identity_condition: entity "wasn't a"i creature_type
                  | entity "is a"i creature_type
                  | entity "is a"i creature_type "card"i
                  | "it" APOSTROPHE "s a"i creature_type "card"i
                  | "it" APOSTROPHE "s a"i creature_type
                  | entity "is"i color
                  | "it was a"i card_type "card"i

// Combat conditions
combat_condition: "it" APOSTROPHE "s attacking"i
                | entity "is attacking"i

// ==================== TARGETS ====================
// Targets
target: "target"i target_description
      | "target"i color target_description
      | "target"i target_description "or"i target_description
      | "target"i color "or"i color target_description
      | "target"i target_description "that's"i color "or"i color
      | "target"i target_description "with"i ability_granted
      | "target"i target_description "with"i stat_condition
      | "target"i "player"i
      | "target"i "opponent"i
      | "target"i combined_type
      | "target"i "player or planeswalker"i
      | "target"i "creature or enchantment an opponent controls"i
      | "target"i "noncreature spell"i
      | "each"i target_description
      | "each"i color target_description
      | "each"i "player"i
      | "each"i "opponent"i
      | "all"i target_description
      | "any"i target_description
      | "that"i target_description
      | "any target"i
      | "another target"i target_description
      | "another target"i target_description "you control"i
      | "another target"i target_description "you own"i
      | "another target"i target_description "with"i stat_condition
      // "target X that player controls" / "target X an opponent controls"
      | "target"i target_description "that player controls"i
      | entity

// Target descriptions
target_description: creature_type object_condition?
                  | permanent_type object_condition?
                  | "player"i
                  | "opponent"i
                  | "creatures"i object_condition?
                  | "spell"i object_condition?
                  | combined_type
                  | "player or planeswalker"i
                  | "attacking or blocking creature"i
                  | "attacking creature"i
                  | "card"i object_condition?
                  | "cards"i object_condition?
                  | "tapped creature"i object_condition?
                  | "nonbasic land"i object_condition?
                  // Typed cards (for targeting cards in zones)
                  | card_type "card"i object_condition?
                  | card_type "or"i card_type "card"i object_condition?
                  | creature_type "card"i object_condition?
                  | creature_type card_type "card"i object_condition?
                  // Plural target descriptions
                  | "nonland permanents"i
                  | "permanents"i

// Conditions for targets (unified)
// Replaces the former creature_condition, permanent_condition, spell_condition, card_condition
object_condition: // Control/ownership
                | "you control"i
                | "you don't control"i
                | "you own"i
                | "an opponent controls"i
                // Properties
                | "with"i ability_granted
                | "with"i stat_condition
                | "with"i counter "on it"i
                // Attachment
                | "attached to"i entity
                // Zone (for cards)
                | "in"i zone
                | "from your graveyard"i
                | "from a graveyard"i
                | "from a graveyard that was put there this turn"i
                | "from"i zone

// ==================== COSTS ====================
// Costs - simple standalone cost patterns (used by activation_cost as base)
cost: // Tap
    | "{T}"
    // Mana
    | mana_cost
    | mana_only_cost
    // Tap + action
    | "{T}, Sacrifice"i sacrifice_target
    | "{T}, Pay"i NUMBER "life"i
    | "{T}, Discard a card"i
    | "{T}" "," "Exile"i exile_target
    // Standalone actions
    | "Sacrifice"i sacrifice_target
    | "Pay"i NUMBER "life"i
    | "Discard a card"i
    | "Exile"i exile_target
    | "Tap"i tap_target
    | "Tap"i NUMBER "untapped"i permanent_type "you control"i
    // Mana + tap
    | mana_only_cost "," "{T}"
    // Mana + sacrifice
    | mana_cost "," "Sacrifice"i sacrifice_target
    | mana_only_cost "," "Sacrifice"i sacrifice_target
    // Mana + tap + sacrifice
    | mana_cost "," "{T}" "," "Sacrifice"i sacrifice_target
    // Mana + tap + return
    | mana_only_cost "," "{T}" "," "Return"i entity "to its owner's hand"i

// Sacrifice targets
sacrifice_target: "it"i
                | "this artifact"i
                | "this creature"i
                | "this enchantment"i
                | "this land"i
                | "this token"i
                | "this"i permanent_type
                | "a"i permanent_type
                | "another"i permanent_type
                | NUMBER permanent_type

// Exile targets
exile_target: "it"i
            | "this card"i
            | "this creature"i
            | "this artifact"i
            | "a"i card_type "card from your graveyard"i
            | "a"i card_type "card from your hand"i
            | NUMBER card_type "cards from your graveyard"i
            | NUMBER card_type "cards from your hand"i

// Tap targets
tap_target: "an untapped"i permanent_type "you control"i
          | NUMBER "untapped"i permanent_type "you control"i

// Search targets - uses object_descriptor for the core description
// The "card"/"cards" ending is handled by object_kind inside obj_type_core
// Examples: "a creature card", "a basic land card", "a green Elf card",
//           "an instant or sorcery card", "basic land cards"
search_target: ("a"i | "an"i) object_descriptor search_qualifier?
             // Compound: "an instant card or a card with flash"
             | ("a"i | "an"i) object_descriptor "or"i ("a"i | "an"i) object_descriptor search_qualifier?
             // Plural (no article): "basic land cards", "creature cards"
             | object_descriptor search_qualifier?
             // Compound plural: "basic land cards and/or Gate cards"
             | object_descriptor "and/or"i object_descriptor

// Qualifiers that follow the core description in search targets
search_qualifier: "with mana value"i comparison_operator? NUMBER ("or greater"i | "or less"i)?
                | "with"i ability_granted
                | "named"i /[A-Za-z, ]+/

// ==================== ENTITIES ====================
// Entities - organized by semantic category
entity: // Self-referential
      | "this"i permanent_type
      | "this spell"i
      | "this card"i
      | "it"i
      | "~"i
      | "~f"i
      | "enchanted creature"i
      | "enchanted permanent"i
      | "equipped creature"i

      // Players
      | "you"i
      | "your opponents"i
      | "each opponent"i
      | "any opponent"i
      | "an opponent"i
      | "each player"i
      | "target player"i
      | "target opponent"i
      | "a player"i
      | "that player"i
      | "its controller"i
      | "its owner"i
      | "their controller"i
      | "that land" APOSTROPHE "s controller"i

      // You control (with optional count/qualifier)
      | "creatures you control"i
      | "other creatures you control"i
      | "all creatures you control"i
      | "each creature you control"i
      | "permanents you control"i
      | "nonland permanents you control"i
      | "lands you control"i
      | NUMBER? permanent_type "you control"i
      | NUMBER? creature_type "you control"i
      | creature_type_plural "you control"i
      | "each other"i creature_type "you control"i
      | "another"i permanent_type "you control"i
      | "another"i creature_type "you control"i
      | "another non-"i creature_type permanent_type "you control"i

      // Opponent controls
      | "creatures your opponents control"i
      | "permanents your opponents control"i
      | NUMBER? permanent_type "an opponent controls"i
      | NUMBER? creature_type "an opponent controls"i

      // Targeted entities
      | "target"i permanent_type
      | "target"i creature_type
      | "target"i spell_type
      | "target"i card_type
      | "another target"i permanent_type
      | "another target"i creature_type
      | "another target"i entity "you control"i

      // Referential (back-references to previously mentioned things)
      | "that"i permanent_type
      | "that"i creature_type
      | "that"i spell_type
      | "that"i card_type
      | "that spell"i
      | "that card"i
      | "that creature or planeswalker"i
      | "those creatures"i
      | "those"i target_description
      | "they"i
      | "the exiled card"i

      // Generic groups
      | "creatures"i
      | "permanents"i
      | "nonland permanents"i
      | "attacking creatures"i
      | "attacking creatures you control"i
      | "cards in your graveyard"i

// ==================== TYPES ====================
// Permanent types
permanent_type: "permanent"i
              | "creature"i
              | "artifact"i
              | "enchantment"i
              | "land"i
              | "planeswalker"i
              | "token"i
              | "Equipment"i
              | "Aura"i
              | "Vehicle"i
              | "Food"i
              | "Treasure"i
              | "Clue"i
              | "Gold"i
              | "Saga"i
              | "nontoken"i permanent_type
              | "noncreature"i permanent_type
              | "nonland"i permanent_type
              | "nonartifact"i permanent_type
              | "nonenchantment"i permanent_type
              | "nonplaneswalker"i permanent_type

// Combined permanent types (shared across enchant_target, target_description, target, etc.)
combined_type: "creature or planeswalker"i
             | "artifact or enchantment"i
             | "creature or enchantment"i
             | "creature or player"i
             | "creature or land"i
             | "creature, land, or planeswalker"i

// Card types
card_type: "creature"i
         | "artifact"i
         | "enchantment"i
         | "instant"i
         | "sorcery"i
         | "land"i
         | "planeswalker"i
         | "basic land"i
         | "nonbasic land"i
         | "nonland"i
         | "noncreature"i
         | "instant or sorcery"i
         | "instant and sorcery"i
         | "permanent"i
         | "nonland permanent"i
         | "noncreature, nonland"i

// Spell types
spell_type: "a spell"i
          | "an instant spell"i
          | "a sorcery spell"i
          | "a creature spell"i
          | "an artifact spell"i
          | "an enchantment spell"i
          | "a planeswalker spell"i
          | "a noncreature spell"i
          | "an instant or sorcery spell"i
          | "a spell with mana value"i comparison_operator NUMBER
          | "a"i color "spell"i
          | "a" color permanent_type "spell"i
          | "a noncreature or"i creature_type "spell"i
          | "a"i color "or"i color card_type "or"i card_type "spell"i
          | "a"i color "or"i color "spell"i

